# Chainer Agent — Environment Configuration
# Copy this file to .env and fill in your values

# Game server URL (required)
GAME_SERVER_URL=https://your-game-server.com
# Legacy compatibility alias also supported:
# ENDPOINT=https://your-game-server.com

# Python PPO training service URL (required)
TRAINER_URL=http://localhost:5555
SUPERVISOR_PORT=3101
DASHBOARD_PORT=3000
# SUPERVISOR_URL=http://localhost:3101

# Room configuration
ROOM_NAME=TimeLimited
# Legacy compatibility alias also supported:
# ROOM=TimeLimited
MAP_NAME=arena
WEAPON_TYPE=rocket

# Training parameters
POPULATION_SIZE=15
# Legacy compatibility alias also supported:
# NUM_CLIENTS=15
MATCH_TIMEOUT=120000
NUM_ROOMS=2
SELECTION_INTERVAL=10
NUM_CULL=5
BOT_ROSTER_PATH=config/roster.json
DEFAULT_POLICY_FAMILY=arena-main
EVALUATION_SAMPLE_MATCHES=3
EVALUATION_PROMOTION_MARGIN=0.05
EVALUATION_MIN_WIN_RATE=0.55

# Required for matchmaker HTTP auth and room join auth
OAUTH_API_KEY=your-oauth-api-key-here

# LLM Strategic Brain (Ollama Cloud)
# OLLAMA_CLOUD_API_KEY=your-api-key-here
# Primary model used by the strategy coach. Defaults to kimi-k2.6:cloud
# (~595B params, much faster than kimi-k2.5's ~1.1T at the same prompt).
# DEEP_ANALYSIS_MODEL=kimi-k2.6:cloud
# Fallback used on a retryable primary failure (timeout / 5xx / 429).
# Defaults to deepseek-v4-flash:cloud — latency-optimised ~140B variant.
# LLM_FALLBACK_MODEL=deepseek-v4-flash:cloud
# Coach timeout in ms. The default is 90s for kimi-class reasoning models;
# drop to ~30s if you switch to a smaller / faster default model.
# STRATEGY_COACH_TIMEOUT_MS=90000

# TLS / deployment safety
# TLS_CA_CERT_PATH=/home/m/chainer-agent/certs/upstream-ca.pem
# ALLOW_INSECURE_TLS_FOR_DEV=1
# NODE_TLS_REJECT_UNAUTHORIZED=0
